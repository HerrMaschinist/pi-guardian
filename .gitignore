# DE / EN
# PI Guardian and Model Router repository ignore rules

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.python-version

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging
build/
dist/
site/
.eggs/
*.egg-info/
*.egg

# Test and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.pyre/
hypothesis/

# Logs
*.log
logs/
*.out
*.err

# Runtime files
*.pid
*.pid.lock
*.sock

# Environment and secrets
.env
.env.*
!.env.example
*.secret
*.secrets
secrets/
private/
*.pem
*.key
*.crt
*.p12
*.pfx

# Local databases and state
*.db
*.sqlite
*.sqlite3
*.db-journal
data/*.db
data/*.sqlite
data/*.sqlite3
state/
tmp/
temp/

# Docker
docker-compose.override.yml
*.tar
*.tar.gz

# Editor and IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Node optional
node_modules/

