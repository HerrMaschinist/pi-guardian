# DE / EN
# Beispielkonfiguration / Example configuration

# --------------------------------------------------
# Allgemein / General
# --------------------------------------------------
APP_NAME=pi-guardian-router
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# --------------------------------------------------
# Ollama / Ollama
# --------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
FAST_MODEL=qwen2.5-coder:1.5b
DEEP_MODEL=qwen2.5-coder:3b

# --------------------------------------------------
# Ressourcensteuerung / Resource control
# --------------------------------------------------
DEFAULT_NUM_CTX=2048
DEFAULT_NUM_THREAD=4
FAST_KEEP_ALIVE=5m
DEEP_KEEP_ALIVE=0m
REQUEST_TIMEOUT_SECONDS=90
MAX_INPUT_CHARS=12000
MAX_PAYLOAD_CHARS=20000

# --------------------------------------------------
# Router-Verhalten / Router behavior
# --------------------------------------------------
ENABLE_REPAIR_RETRY=true
ENABLE_DEEP_FALLBACK=true
MAX_REPAIR_ATTEMPTS=1
MAX_DEEP_FALLBACKS=1
SERIAL_EXECUTION=true

# --------------------------------------------------
# API / API
# --------------------------------------------------
API_PREFIX=/api/v1
ENABLE_DOCS=true

# --------------------------------------------------
# Sicherheit / Security
# --------------------------------------------------
ALLOW_FORCE_MODEL=false
INTERNAL_API_TOKEN=CHANGE_ME

# --------------------------------------------------
# Logging / Logging
# --------------------------------------------------
LOG_JSON=false
LOG_REQUESTS=true
LOG_CLASSIFICATION=true
LOG_MODEL_SELECTION=true
LOG_FALLBACKS=true
